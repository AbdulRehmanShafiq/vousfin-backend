# MongoDB
MONGO_URI=mongodb://localhost:27017/vousfin

# Auth
JWT_SECRET=your-jwt-secret-here
CLIENT_URL=http://localhost:5173

# AI — single provider (DeepSeek). Used by natural-language transaction
# parsing, the AI assistant, how-to search, and the faithfulness judge.
# Get a key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=

# AI Assistant RAG
AI_RAG_ENABLED=false
AI_RAG_INDEXER_ENABLED=true
AI_RAG_EVENT_INDEXER_ENABLED=true
RAG_EVENT_REINDEX_DELAY_MS=300000
AI_RAG_STREAMING_ENABLED=true
AI_RETRIEVAL_STATS_ENABLED=false
VECTOR_SEARCH_INDEX_NAME=vousfin_vector_index
VECTOR_SEARCH_NUM_CANDIDATES=150
VECTOR_LOCAL_SCAN_LIMIT=1500
VECTOR_SEARCH_DISABLE=false
# Embeddings are always local/deterministic (DeepSeek has no embeddings API) —
# see services/embeddingService.js. EMBEDDING_DIMENSIONS must match the Atlas
# Vector Search index (VECTOR_SEARCH_INDEX_NAME above).
EMBEDDING_DIMENSIONS=768
RAG_TOP_K=8
RAG_CANDIDATES=40
RAG_MIN_SIMILARITY=0.15
RAG_MAX_CONTEXT_CHARS=14000
RAG_KEYWORD_WEIGHT=0.25
RAG_INDEXER_CRON=0 2 * * *
RAG_INDEXER_TIMEZONE=Asia/Karachi
RAG_INDEX_MAX_RECORDS_PER_TYPE=5000
RAG_INDEX_REPORT_MONTHS=13
HF_API_KEY=
HF_RERANKER_URL=https://api-inference.huggingface.co/models/BAAI/bge-reranker-v2-m3
RERANK_DISABLE=false
AI_FAITHFULNESS_ENABLED=false
AI_MODEL_TIMEOUT_MS=30000
