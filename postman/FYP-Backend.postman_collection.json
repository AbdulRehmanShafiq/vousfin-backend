{
  "info": {
    "name": "FYP Backend API",
    "description": "Import this collection in Postman. Set `baseUrl` (default http://localhost:5000) and run Auth > Login to save `token` automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "accountId", "value": "" },
    { "key": "transactionId", "value": "" },
    { "key": "customerId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        { "name": "GET /health", "request": { "method": "GET", "url": "{{baseUrl}}/health" } },
        { "name": "GET /api/v1/health", "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/health" } }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Test User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"Test@1234\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Test@1234\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"<verification_token_from_db>\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/verify-email"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/auth/logout"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"user@example.com\"\n}" },
            "url": "{{baseUrl}}/api/v1/auth/forgot-password"
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<reset_token>\",\n  \"newPassword\": \"Test@5678\",\n  \"confirmPassword\": \"Test@5678\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/reset-password"
          }
        }
      ]
    },
    {
      "name": "Business",
      "item": [
        {
          "name": "Create Business",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"My Business\",\n  \"businessType\": \"Freelancer\",\n  \"currency\": \"PKR\",\n  \"fiscalYearStartMonth\": 1\n}"
            },
            "url": "{{baseUrl}}/api/v1/business"
          }
        },
        {
          "name": "Get Business",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/business?includeAccountCount=true"
          }
        },
        {
          "name": "List Accounts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/business/accounts"
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create (Form)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionDate\": \"2025-06-01T00:00:00.000Z\",\n  \"description\": \"Rent payment\",\n  \"transactionType\": \"Expense\",\n  \"amount\": 1000,\n  \"debitAccountId\": \"{{accountId}}\",\n  \"creditAccountId\": \"{{accountId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/transactions/form"
          }
        },
        {
          "name": "List Transactions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/transactions?page=1&limit=25"
          }
        },
        {
          "name": "Upload Excel",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "src": "" }]
            },
            "url": "{{baseUrl}}/api/v1/transactions/excel"
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Income Statement",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/reports/income-statement?startDate=2025-01-01&endDate=2025-12-31"
          }
        },
        {
          "name": "Export PDF",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/reports/export?type=incomeStatement&format=pdf&startDate=2025-01-01&endDate=2025-12-31"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "All Dashboard Data",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/dashboard/all"
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "Parse NL",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Paid 500 for utilities from cash\"\n}" },
            "url": "{{baseUrl}}/api/v1/ai/parse-nl"
          }
        },
        {
          "name": "Anomaly Scan",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/ai/anomaly-scan"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/admin/stats"
          }
        },
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/api/v1/admin/customers"
          }
        }
      ]
    }
  ]
}
